<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Songbook</title>
  <style>
    * { box-sizing: border-box; }

    body {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 9pt;
      line-height: 1.35;
      color: #000;
      margin: 0;
      padding: 0;
      hyphens: none;
      -webkit-hyphens: none;
      word-break: normal;
      overflow-wrap: normal;
    }

    :root {
      --chord-rail-height: 1.35em;
    }

    .columns {
      column-count: 3;
      column-gap: 26px;
      column-fill: auto;
      hyphens: none;
      -webkit-hyphens: none;
    }

    .song {
      margin-bottom: 1.1em;
    }

    .song-index {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 9pt;
      font-weight: 700;
      margin: 0 0 0.35em;
      break-after: avoid;
    }

    .stanza-inline {
      font-family: Arial, Helvetica, sans-serif;
      font-weight: 700;
      font-size: 9pt;
      margin-right: 0.35em;
    }

    /* Keep stanza / chorus together in one column when the engine allows */
    .stanza-block,
    .chorus-block {
      break-inside: avoid;
      page-break-inside: avoid;
      -webkit-column-break-inside: avoid;
      hyphens: none;
      -webkit-hyphens: none;
      word-break: normal;
      overflow-wrap: normal;
    }

    .stanza-block + .stanza-block {
      margin-top: 1.2em;
      padding-top: 0.75em;
    }

    .chorus-block {
      margin: 0.85em 0 0.95em;
      padding: 0.65em 0 0.7em 0.25em;
    }

    .chorus-block .lyric-line:first-child {
      margin-top: 0;
    }

    .chorus-block .lyric-line:last-child {
      margin-bottom: 0;
    }

    .stanza-section-br {
      margin: 0.5em 0 0.6em;
      line-height: 0;
    }

    .lyric-meta {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 7.5pt;
      color: #333;
      font-style: italic;
      margin: 0.15em 0;
      white-space: pre-wrap;
      hyphens: none;
      -webkit-hyphens: none;
      word-break: normal;
      overflow-wrap: normal;
    }

    .lyric-spacer {
      height: 0.3em;
    }

    .lyric-line {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 9pt;
      margin: 0.06em 0;
      hyphens: none;
      -webkit-hyphens: none;
      word-break: normal;
      overflow-wrap: normal;
    }

    /* One source line: all chord cells share the same rail; align bottoms with stanza number */
    .lyric-line.chord-line {
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      align-items: flex-end;
      line-height: 1.35;
      word-break: normal;
      overflow-wrap: normal;
      break-inside: avoid;
      page-break-inside: avoid;
      -webkit-column-break-inside: avoid;
    }

    .lyric-line.chord-line > .stanza-inline {
      align-self: flex-end;
      margin-right: 0.15em;
    }

    .lyric-line.lyric-plain {
      white-space: pre-wrap;
      word-break: normal;
      overflow-wrap: normal;
      break-inside: avoid;
      page-break-inside: avoid;
      -webkit-column-break-inside: avoid;
    }

    .cw {
      display: inline-flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-end;
      vertical-align: bottom;
      margin-right: 0.2em;
      font-family: Arial, Helvetica, sans-serif;
      max-width: 100%;
    }

    .cw .ch {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 6.25pt;
      font-weight: 600;
      min-height: var(--chord-rail-height);
      line-height: var(--chord-rail-height);
      display: flex;
      align-items: flex-end;
      color: #000;
      white-space: nowrap;
      box-sizing: border-box;
    }

    .cw .txt {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 9pt;
      min-height: 1.2em;
      line-height: 1.35;
      white-space: normal;
      hyphens: none;
      -webkit-hyphens: none;
      word-break: normal;
      overflow-wrap: normal;
    }
  </style>
</head>
<body>
  <div class="columns">
    <%= yield %>
  </div>
</body>
</html>
