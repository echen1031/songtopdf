<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Songbook</title>
  <style>
    * { box-sizing: border-box; }

    body {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 9pt;
      line-height: 1.35;
      color: #000;
      margin: 0;
      padding: 0;
      hyphens: none;
      -webkit-hyphens: none;
      word-break: normal;
      overflow-wrap: normal;
    }

    :root {
      --chord-rail-height: 1.35em;
    }

    .columns {
      column-count: 3;
      column-gap: 26px;
      column-fill: auto;
      hyphens: none;
      -webkit-hyphens: none;
    }

    .song {
      margin-bottom: 1.1em;
    }

    .song-index {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 9pt;
      font-weight: 700;
      margin: 0 0 0.35em;
    }

    .stanza-inline {
      font-family: Arial, Helvetica, sans-serif;
      font-weight: 700;
      font-size: 9pt;
      margin-right: 0.35em;
    }

    /* Title + first stanza live together in .song-anchor — never split apart */
    .song-anchor {
      break-inside: avoid;
      page-break-inside: avoid;
      -webkit-column-break-inside: avoid;
      overflow: hidden;
    }

    /* Keep each subsequent stanza / chorus together within its column */
    .stanza-block,
    .chorus-block {
      break-inside: avoid;
      page-break-inside: avoid;
      -webkit-column-break-inside: avoid;
      overflow: hidden;
      hyphens: none;
      -webkit-hyphens: none;
      word-break: normal;
      overflow-wrap: normal;
    }

    /* Spacing between consecutive stanza-blocks or after the song-anchor */
    .stanza-block + .stanza-block,
    .song-anchor + .stanza-block {
      margin-top: 1.2em;
      padding-top: 0.75em;
    }

    /* Chorus lives inside its stanza-block; give it the same top spacing so
       the gap above matches the gap below (which comes from the next stanza-block) */
    .chorus-block {
      margin-top: 1.2em;
      padding: 0.75em 0 0 0.25em;
    }

    .chorus-block .lyric-line:first-child {
      margin-top: 0;
    }

    .chorus-block .lyric-line:last-child {
      margin-bottom: 0;
    }

    .lyric-meta {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 7.5pt;
      color: #333;
      font-style: italic;
      margin: 0.15em 0;
      white-space: pre-wrap;
      hyphens: none;
      -webkit-hyphens: none;
      word-break: normal;
      overflow-wrap: normal;
    }

    .lyric-spacer {
      height: 0.3em;
    }

    .lyric-line {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 9pt;
      margin: 0.06em 0;
      hyphens: none;
      -webkit-hyphens: none;
      word-break: normal;
      overflow-wrap: normal;
    }

    /* One source line: all chord cells share the same rail; align bottoms with stanza number.
       flex-wrap: nowrap keeps the whole line on one row — overflow is clipped by the
       stanza-block's overflow:hidden rather than wrapping to a second line. */
    .lyric-line.chord-line {
      display: flex;
      flex-direction: row;
      flex-wrap: nowrap;
      align-items: flex-end;
      line-height: 1.35;
      break-inside: avoid;
      page-break-inside: avoid;
      -webkit-column-break-inside: avoid;
    }

    .lyric-line.chord-line > .stanza-inline {
      align-self: flex-end;
      flex-shrink: 0;
      margin-right: 0.35em;
    }

    /* white-space: nowrap keeps each lyric line on a single row.
       Overflow is clipped by the parent stanza-block's overflow:hidden. */
    .lyric-line.lyric-plain {
      white-space: nowrap;
      break-inside: avoid;
      page-break-inside: avoid;
      -webkit-column-break-inside: avoid;
    }

    .cw {
      display: inline-flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-end;
      vertical-align: bottom;
      flex-shrink: 0;
      margin-right: 0.2em;
      font-family: Arial, Helvetica, sans-serif;
    }

    /* Mid-word chord: no gap between this unit and the next syllable */
    .cw.cw-tight {
      margin-right: 0;
    }

    .cw .ch {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 6.25pt;
      font-weight: 600;
      min-height: var(--chord-rail-height);
      line-height: var(--chord-rail-height);
      display: flex;
      align-items: flex-end;
      color: #000;
      white-space: nowrap;
      box-sizing: border-box;
    }

    .cw .txt {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 9pt;
      min-height: 1.2em;
      line-height: 1.35;
      white-space: nowrap;
    }
  </style>
</head>
<body>
  <div class="columns">
    <%= yield %>
  </div>
</body>
</html>
